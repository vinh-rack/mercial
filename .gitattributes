# .gitattributes
# Auto-detect text files and normalize line endings
* text=auto eol=lf
# Force LF endings for code
*.py text eol=lf
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
# Keep binary files untouched
*.png binary
*.jpg binary
*.pdf binary
*.docx binary
*.sqlite3 binary
*.mp4 filter=lfs diff=lfs merge=lfs -text
